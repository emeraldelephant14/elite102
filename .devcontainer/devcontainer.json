{
    "name": "Python 3",
    "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.shell.linux": "/bin/bash"
            },
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "qwtel.sqlite-viewer"
            ]
        }
    },
    "mounts": [
        "source=${localWorkspaceFolder}/data,target=/home/vscode/data,type=bind,consistency=cached"
    ],
    "forwardPorts": [],
    "postCreateCommand": "apt-get update && apt-get install -y sqlite3 libsqlite3-dev && python -m venv .venv && source .venv/bin/activate && pip install --user -r requirements.txt",
    "remoteUser": "vscode"
}